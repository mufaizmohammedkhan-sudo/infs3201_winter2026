<h1>Employee Details</h1>

<p><strong>ID:</strong> {{employee.employeeId}}</p>
<p><strong>Name:</strong> {{employee.name}}</p>
<p><strong>Phone:</strong> {{employee.phone}}</p>

<p>
  <a href="/employee/{{employee.employeeId}}/edit">Edit Details</a>
</p>

<h2>Shifts</h2>

{{#if shifts.length}}
<table border="1" cellpadding="6" cellspacing="0">
  <tr>
    <th>Date</th>
    <th>Start</th>
    <th>End</th>
  </tr>

  {{#each shifts}}
  <tr>
    <td>{{date}}</td>

    <!-- Morning shifts (<12:00) become yellow -->
    <td class="{{#if isMorning}}morning{{/if}}">
      {{startTime}}
    </td>

    <td>{{endTime}}</td>
  </tr>
  {{/each}}

</table>
{{else}}
<p>No shifts found for this employee.</p>
{{/if}}

<p><a href="/">Back to Employees</a></p>